# Copy this to .env and adjust. .env itself is gitignored — never commit real secrets.

TERMAID_ROOT=C:\Termaid\termaid-cli
DEPLOYMENT_MODE=local

# comma-separated overrides, e.g. MODULE_EXTRA_ALLOW="git,docker"
# DANGEROUS-tier modules (see backend/policy.py) require explicit opt-in here
# even in local mode. Leave empty until you know which ones you actually want.
MODULE_EXTRA_ALLOW=
MODULE_EXTRA_DENY=

# AI provider (leave blank to run without AI-backed modules)
AI_PROVIDER=

DATABASE_URL=sqlite+aiosqlite:///./termaid_web.db
JWT_SECRET=change_me_to_a_real_random_secret

# Seeded root/admin account (app-level is_admin role — NOT the OS-level
# /admin CLI module, which is a separate thing). Leave both as CHANGE_ME_...
# and no admin account is ever created. Set both to enable it: seeded (or
# re-affirmed) on every backend boot, and that exact username can never be
# self-registered by anyone else. Gates GET/POST/DELETE /api/admin/* (user
# list/disable/enable/delete + a merged system-health view).
ADMIN_USERNAME=CHANGE_ME_admin_username
ADMIN_PASSWORD=CHANGE_ME_use_a_real_password
