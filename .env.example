# Copy this to .env and adjust. .env itself is gitignored — never commit real secrets.

TERMAID_ROOT=C:\Termaid\termaid-cli
DEPLOYMENT_MODE=local

# comma-separated overrides, e.g. MODULE_EXTRA_ALLOW="git,docker"
# DANGEROUS-tier modules (see backend/policy.py) require explicit opt-in here
# even in local mode. Leave empty until you know which ones you actually want.
MODULE_EXTRA_ALLOW=
MODULE_EXTRA_DENY=

# AI provider (leave blank to run without AI-backed modules)
AI_PROVIDER=

DATABASE_URL=sqlite+aiosqlite:///./termaid_web.db
JWT_SECRET=change_me_to_a_real_random_secret
